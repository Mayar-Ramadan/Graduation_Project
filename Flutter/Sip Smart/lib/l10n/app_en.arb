  "privacy_last_updated": "Last Updated: June 18, 2026",
  "privacy_introduction_title": "Introduction",
  "privacy_introduction_content": "Smart Sip is committed to protecting your privacy. This Privacy Policy explains how we collect, use, and safeguard your personal information when you use our app.",
  "privacy_collect_title": "Information We Collect",
  "privacy_collect_content": "We collect the following types of information to improve your hydration experience:",
  "privacy_collect_bullet_1": "Personal information: name, email address, and profile details",
  "privacy_collect_bullet_2": "Health data: age, weight, height, and daily hydration goals",
  "privacy_collect_bullet_3": "Usage data: app interactions, drinking patterns, and preferences",
  "privacy_collect_bullet_4": "Device data: bottle model, connection status, and battery level",
  "privacy_collect_bullet_5": "Location data: city and weather information for personalized suggestions",
  "privacy_use_title": "How We Use Your Information",
  "privacy_use_content": "We use your data for the following purposes:",
  "privacy_use_bullet_1": "To provide personalized hydration recommendations",
  "privacy_use_bullet_2": "To track your daily water intake and progress",
  "privacy_use_bullet_3": "To send AI-powered reminders and notifications",
  "privacy_use_bullet_4": "To integrate with weather data for smart hydration tips",
  "privacy_use_bullet_5": "To improve app performance and user experience",
  "privacy_use_bullet_6": "To provide customer support and feedback assistance",
  "privacy_use_bullet_7": "To analyze trends and enhance features",
  "privacy_storage_title": "Data Storage & Security",
  "privacy_storage_content": "All data is stored securely in Firebase Realtime Database with encryption at rest. We implement industry-standard security measures to protect against unauthorized access, data loss, or misuse.",
  "privacy_sharing_title": "Data Sharing",
  "privacy_sharing_content": "We do not sell your data to third parties. However, we may share data in the following cases:",
  "privacy_sharing_bullet_1": "With your explicit consent",
  "privacy_sharing_bullet_2": "To comply with legal obligations",
  "privacy_sharing_bullet_3": "To protect our rights and safety",
  "privacy_sharing_bullet_4": "With trusted service providers (e.g., Firebase, weather APIs)",
  "privacy_sharing_bullet_5": "In aggregated, anonymized form for analytics",
  "privacy_rights_title": "Your Rights",
  "privacy_rights_content": "You have the following rights regarding your personal data:",
  "privacy_rights_bullet_1": "Access your data at any time",
  "privacy_rights_bullet_2": "Request corrections to inaccurate information",
  "privacy_rights_bullet_3": "Delete your account and associated data",
  "privacy_rights_bullet_4": "Object to or restrict data processing",
  "privacy_rights_bullet_5": "Export your data in a portable format",
  "privacy_rights_bullet_6": "Withdraw consent at any time",
  "privacy_third_party_title": "Third-Party Services",
  "privacy_third_party_content": "We integrate with third-party services including Firebase (data storage), weather APIs (location data), and analytics tools to improve our app. These services have their own privacy policies.",
